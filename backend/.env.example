# ENV_REQUIRED
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/benefits_readiness

# ENV_REQUIRED for Gemini extraction; mock extraction works without it.
GEMINI_API_KEY=

# ENV_REQUIRED
UPLOAD_PATH=./uploads

GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=30
USE_GEMINI_EXTRACTOR=false
MAX_UPLOAD_BYTES=10485760
CHROMA_PATH=./chroma_data
RAG_MIN_RELEVANCE=0.35
RAG_TOP_N=3
LOG_LEVEL=INFO
ENVIRONMENT=development
